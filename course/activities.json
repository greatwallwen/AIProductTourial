{
  "schema": "learning-activity-catalog/v1",
  "courseId": "ai-product-loop-engineering",
  "activities": [
    {
      "id": "act-01-sensor-contract",
      "moduleId": "m01-evidence-first",
      "title": "拆解一个传感器契约",
      "kind": "inspect",
      "required": true,
      "durationMinutes": 25,
      "validator": "sensor-contract/v1",
      "command": "node code/tools/verify_course_package.mjs",
      "runtimeJob": {"id": "job-sensor-contract", "type": "loop_run", "title": "传感器契约基线", "allowlistRef": "course-sensor-baseline"},
      "submission": {"format": "json", "requiredFields": ["goal", "signals", "failureLocation", "stopCondition"]},
      "evidence": {"required": true, "types": ["stdout", "exit-code", "sensor-list"], "verification": "deterministic"},
      "rubricId": "rubric-evidence-loop",
      "roleCoverage": ["engineering", "product", "assurance"]
    },
    {
      "id": "act-02-mutant-kill",
      "moduleId": "m01-evidence-first",
      "title": "杀死一个关键词投机变异体",
      "kind": "red-team",
      "required": true,
      "durationMinutes": 35,
      "validator": "mutant-kill/v1",
      "command": "node --test code/tools/course_contract.test.mjs",
      "runtimeJob": {"id": "job-mutant-kill", "type": "loop_run", "title": "反作弊变异测试", "allowlistRef": "learning-mutant-kill"},
      "submission": {"format": "json", "requiredFields": ["mutant", "oldSensorResult", "newSensorResult", "why"]},
      "evidence": {"required": true, "types": ["test-report", "mutant-diff"], "verification": "deterministic"},
      "rubricId": "rubric-evidence-loop",
      "roleCoverage": ["engineering", "product", "assurance"]
    },
    {
      "id": "act-03-loop-success",
      "moduleId": "m02-bounded-loop",
      "title": "跑通一个两轮收敛的 Loop",
      "kind": "execute",
      "required": true,
      "durationMinutes": 35,
      "validator": "bounded-loop-success/v1",
      "command": "node code/labs/loop/run.mjs --scenario converge",
      "runtimeJob": {"id": "job-loop-success", "type": "loop_run", "title": "两轮收敛 Loop", "allowlistRef": "bounded-loop-converge"},
      "submission": {"format": "json", "requiredFields": ["goal", "maxTurns", "cycles", "stopReason", "traceHash"]},
      "evidence": {"required": true, "types": ["loop-trace", "stop-reason", "hash"], "verification": "deterministic"},
      "rubricId": "rubric-bounded-loop",
      "roleCoverage": ["engineering", "product", "assurance"]
    },
    {
      "id": "act-04-loop-stop",
      "moduleId": "m02-bounded-loop",
      "title": "证明 Loop 会在重复失败时停机",
      "kind": "failure-drill",
      "required": true,
      "durationMinutes": 50,
      "validator": "bounded-loop-stop/v1",
      "command": "node code/labs/loop/run.mjs --scenario repeated-failure",
      "runtimeJob": {"id": "job-loop-stop", "type": "loop_run", "title": "重复失败停机演练", "allowlistRef": "bounded-loop-repeated-failure"},
      "submission": {"format": "json", "requiredFields": ["failureFingerprint", "attempts", "stopReason", "escalationPacket"]},
      "evidence": {"required": true, "types": ["loop-trace", "failure-fingerprint", "escalation-packet"], "verification": "deterministic"},
      "rubricId": "rubric-bounded-loop",
      "roleCoverage": ["engineering", "product", "assurance"]
    },
    {
      "id": "act-05-skill-package",
      "moduleId": "m03-skill-engineering",
      "title": "写一个渐进披露 Skill 包",
      "kind": "author",
      "required": true,
      "durationMinutes": 30,
      "validator": "skill-package/v1",
      "command": "node code/labs/skills/validate.mjs course/fixtures/skills/good/SKILL.md",
      "runtimeJob": {"id": "job-skill-package", "type": "skill_validate", "title": "Skill 包验证", "allowlistRef": "agent-skill-package"},
      "submission": {"format": "markdown", "requiredFields": ["frontmatter", "trigger", "workflow", "verification", "references"]},
      "evidence": {"required": true, "types": ["validation-report", "loaded-resources"], "verification": "deterministic"},
      "rubricId": "rubric-skill",
      "roleCoverage": ["engineering", "product", "assurance"]
    },
    {
      "id": "act-06-skill-red-team",
      "moduleId": "m03-skill-engineering",
      "title": "让扫描器拦住投毒 Skill",
      "kind": "red-team",
      "required": true,
      "durationMinutes": 40,
      "validator": "skill-red-team/v1",
      "command": "node code/labs/skills/validate.mjs course/fixtures/skills/poisoned/SKILL.md --expect-blocked",
      "runtimeJob": {"id": "job-skill-red-team", "type": "skill_validate", "title": "Skill 投毒演练", "allowlistRef": "agent-skill-red-team"},
      "submission": {"format": "json", "requiredFields": ["finding", "severity", "blocked", "remediation"]},
      "evidence": {"required": true, "types": ["security-findings", "exit-code"], "verification": "deterministic"},
      "rubricId": "rubric-skill",
      "roleCoverage": ["engineering", "product", "assurance"]
    },
    {
      "id": "act-07-mcp-handshake",
      "moduleId": "m04-mcp-contract",
      "title": "跑通 MCP 初始化与原语发现",
      "kind": "protocol-probe",
      "required": true,
      "durationMinutes": 35,
      "validator": "mcp-handshake/v1",
      "command": "node code/labs/mcp/client.mjs",
      "runtimeJob": {"id": "job-mcp-handshake", "type": "mcp_probe", "title": "MCP 能力协商", "allowlistRef": "mcp-capability-handshake"},
      "submission": {"format": "json", "requiredFields": ["protocolVersion", "clientCapabilities", "serverCapabilities", "discoveredPrimitives"]},
      "evidence": {"required": true, "types": ["json-rpc-trace", "capability-matrix"], "verification": "deterministic"},
      "rubricId": "rubric-mcp",
      "roleCoverage": ["engineering", "product", "assurance"]
    },
    {
      "id": "act-08-mcp-threat-model",
      "moduleId": "m04-mcp-contract",
      "title": "画出 MCP 信任与授权边界",
      "kind": "threat-model",
      "required": true,
      "durationMinutes": 35,
      "validator": "mcp-threat-model/v1",
      "command": "node code/labs/mcp/client.mjs --probe-denied",
      "runtimeJob": {"id": "job-mcp-threat", "type": "mcp_probe", "title": "MCP 越权探针", "allowlistRef": "mcp-denied-capability"},
      "submission": {"format": "json", "requiredFields": ["assets", "trustBoundaries", "abuseCases", "mitigations"]},
      "evidence": {"required": true, "types": ["denied-call", "threat-model"], "verification": "mixed"},
      "rubricId": "rubric-mcp",
      "roleCoverage": ["engineering", "product", "assurance"]
    },
    {
      "id": "act-09-rag-improvement",
      "moduleId": "m05-evals-data",
      "title": "用真实调用的 eval 驱动一次改进",
      "kind": "evaluation",
      "required": true,
      "durationMinutes": 50,
      "validator": "rag-improvement/v1",
      "command": "node code/tools/eval_harness.mjs --json",
      "runtimeJob": {"id": "job-rag-improvement", "type": "rag_query", "title": "RAG 基线与改进", "allowlistRef": "tutorial-rag-eval"},
      "submission": {"format": "json", "requiredFields": ["baseline", "change", "after", "regressions", "decision"]},
      "evidence": {"required": true, "types": ["eval-report", "retrieval-trace", "before-after"], "verification": "deterministic"},
      "rubricId": "rubric-evals-data",
      "roleCoverage": ["engineering", "product", "assurance"]
    },
    {
      "id": "act-10-dataset-decision",
      "moduleId": "m05-evals-data",
      "title": "从数据查询走到可追责决策",
      "kind": "dataset-query",
      "required": true,
      "durationMinutes": 55,
      "validator": "dataset-decision/v1",
      "command": "node code/labs/data/query.mjs --fixture defi-risk",
      "runtimeJob": {"id": "job-dataset-decision", "type": "dataset_sql", "title": "DeFi 风险分层查询", "allowlistRef": "defi-risk-sql"},
      "submission": {"format": "json", "requiredFields": ["queryId", "resultHash", "anomaly", "decision", "owner", "reviewBy"]},
      "evidence": {"required": true, "types": ["dataset-profile", "query-result", "decision-record"], "verification": "mixed"},
      "rubricId": "rubric-evals-data",
      "roleCoverage": ["engineering", "product", "assurance"]
    },
    {
      "id": "act-11-sdd-trace",
      "moduleId": "m06-sdd-capstone",
      "title": "建立需求到测试的双向追溯",
      "kind": "traceability",
      "required": true,
      "durationMinutes": 40,
      "validator": "sdd-trace/v1",
      "command": "node code/tools/build_html_ppt_course.mjs",
      "runtimeJob": {"id": "job-sdd-trace", "type": "doc_export", "title": "课程追溯矩阵", "allowlistRef": "learning-trace-export"},
      "submission": {"format": "json", "requiredFields": ["requirements", "tasks", "tests", "evidenceRefs", "uncovered"]},
      "evidence": {"required": true, "types": ["traceability-matrix", "coverage-summary"], "verification": "deterministic"},
      "rubricId": "rubric-sdd-capstone",
      "roleCoverage": ["engineering", "product", "assurance"]
    },
    {
      "id": "act-12-capstone-review",
      "moduleId": "m06-sdd-capstone",
      "title": "提交三角色审计的结业项目",
      "kind": "capstone",
      "required": true,
      "durationMinutes": 65,
      "validator": "capstone-review/v1",
      "command": "node code/tools/audit_learning_course.mjs",
      "runtimeJob": {"id": "job-capstone-review", "type": "doc_export", "title": "结业证据包", "allowlistRef": "learning-capstone-export"},
      "submission": {"format": "json", "requiredFields": ["problem", "metric", "spec", "sensor", "loopBoundary", "evidenceRefs", "residualRisks"]},
      "evidence": {"required": true, "types": ["capstone-bundle", "role-reviews", "human-signoff"], "verification": "mixed"},
      "rubricId": "rubric-sdd-capstone",
      "roleCoverage": ["engineering", "product", "assurance"]
    }
  ]
}
