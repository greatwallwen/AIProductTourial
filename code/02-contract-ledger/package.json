{
  "name": "contract-ledger",
  "version": "1.0.0",
  "private": true,
  "description": "企业合同管理系统——《信息化产品系统架构设计实操教程》案例二示例工程",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node src/server.ts",
    "dev": "node --watch src/server.ts",
    "db:migrate": "node src/db/migrate.ts",
    "db:seed": "node src/db/seed.ts",
    "db:reset": "node src/db/migrate.ts --fresh && node src/db/seed.ts",
    "test": "node --test \"tests/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.ts",
    "verify": "npm run typecheck && npm test && npm run smoke"
  },
  "dependencies": {
    "@fastify/swagger": "^9.5.0",
    "fastify": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.0"
  }
}
